    {"step": 4, "action": "click", "selector": "button[type=submit],button:has-text('登录')", "value": "", "desc": "点击登录按钮", "assert": {"type": "", "expected": ""}},
    {"step": 5, "action": "assert", "selector": "", "value": "", "desc": "验证登录成功", "assert": {"type": "url_contains", "expected": "/dashboard"}},
    {"step": 6, "action": "assert", "selector": "", "value": "", "desc": "验证页面加载成功", "assert": {"type": "text_exists", "expected": "欢迎"}}
  ]
